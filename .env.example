# Configuration for Predict System

## Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

## File Upload Settings
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt

## Prediction Settings
MIN_PAPERS_FOR_PREDICTION=2
PREDICTION_CONFIDENCE_THRESHOLD=0.4

## Database (future)
# DATABASE_URL=sqlite:///predict.db

## Frontend
FRONTEND_PORT=3000

## Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
